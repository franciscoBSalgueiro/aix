# name: test/sql/is_valid_movedata.test
# description: test is_valid_movedata function
# group: [sql]


require aixchess


query I
SELECT is_valid_movedata('\x9F-\x84\x1C\x1A\x9D:\xBD\xB3\xB8'::BLOB);
----
true


query I
SELECT is_valid_movedata('\x0C\x1C4$\x05\x1A9*\x06\x151)\x04\x07>-\x0A\x12=\x22\x9A5\xBC5\x15&5>\x03\x11-#\x91#>=#5\x00'::BLOB);
----
true


query I
SELECT is_valid_movedata('<]\x93.\x0DT?\xE2\xEC\xDE\xEFaFR\x973\xDB\x03v'::BLOB);
----
true


query I
SELECT is_valid_movedata('\x9F-\x84\x1C\xA1\xD9:\xBD\xB3\xB8'::BLOB);
----
false


query I
SELECT is_valid_movedata('\x0C\x1C4$\x05\x1A9*\x06\x151)\x40\x07>-\x0A\x12=\x22\x9A5\xBC5\x51&5>\x03\x11-#\x91#>=#5\x00'::BLOB);
----
false


query I
SELECT is_valid_movedata('<]\x93.\x0DT?\xE2\xCE\xDE\xEFaFR\x974\xDB\x03v'::BLOB);
----
false


query I
SELECT is_valid_movedata('invalid'::BLOB);
----
false

